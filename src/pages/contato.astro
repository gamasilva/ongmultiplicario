---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MapPin, Phone, Mail, Clock } from 'lucide-astro';

const title = "Contato";
const description = "Fale com o Instituto MultiplicaRio. Estamos abertos a parcerias, dúvidas e novos voluntários na Penha, RJ.";
---

<BaseLayout title={title} description={description}>
  <!-- Page Header -->
  <section class="bg-bg-lightgreen py-20 border-b border-primary/10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-primary-dark mb-6">Fale Conosco</h1>
      <p class="text-xl text-text-body/80 leading-relaxed">
        Dúvidas, parcerias ou vontade de ser voluntário? Estamos de braços abertos para conversar com você.
      </p>
    </div>
  </section>

  <section class="py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16">
        
        <!-- Informações de Contato -->
        <div class="lg:w-1/3 space-y-8">
          <div>
            <h2 class="font-serif text-3xl font-bold text-primary-dark mb-6">Informações</h2>
            <p class="text-text-body/80 mb-8">Nossa equipe responderá o mais breve possível. Para assuntos urgentes, prefira o contato por telefone.</p>
          </div>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary flex-shrink-0 shadow-sm border border-gray-100">
                <MapPin class="w-6 h-6" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-bold text-primary-dark">Endereço</h3>
                <p class="text-text-body/80 mt-1">Rua Montevideo, 824 - Loja F<br/>Penha, Rio de Janeiro - RJ<br/>CEP: 21020-290</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary flex-shrink-0 shadow-sm border border-gray-100">
                <Phone class="w-6 h-6" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-bold text-primary-dark">Telefone / WhatsApp</h3>
                <p class="text-text-body/80 mt-1">(21) 6459-4790</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary flex-shrink-0 shadow-sm border border-gray-100">
                <Mail class="w-6 h-6" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-bold text-primary-dark">E-mail</h3>
                <p class="text-text-body/80 mt-1">imultiplicar@gmail.com</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary flex-shrink-0 shadow-sm border border-gray-100">
                <Clock class="w-6 h-6" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-bold text-primary-dark">Horário de Atendimento</h3>
                <p class="text-text-body/80 mt-1">Segunda a Sexta: 09h às 18h</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulário e Mapa -->
        <div class="lg:w-2/3 space-y-12">
          
          <!-- Formulário -->
          <div class="bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-gray-100">
            <h2 class="font-serif text-2xl font-bold text-primary-dark mb-6">Envie uma mensagem</h2>
            
            <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Nome Completo</label>
                  <input type="text" name="name" id="name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none bg-bg-offwhite" placeholder="Seu nome" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-2">E-mail</label>
                  <input type="email" name="email" id="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none bg-bg-offwhite" placeholder="seu@email.com" />
                </div>
              </div>
              
              <div>
                <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">Assunto</label>
                <select name="subject" id="subject" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none bg-bg-offwhite">
                  <option value="Dúvida Geral">Dúvida Geral</option>
                  <option value="Quero ser Voluntário">Quero ser Voluntário</option>
                  <option value="Parceria Institucional">Parceria Institucional</option>
                  <option value="Doações">Doações</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Mensagem</label>
                <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none bg-bg-offwhite resize-y" placeholder="Como podemos ajudar?"></textarea>
              </div>

              <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary">
                Enviar Mensagem
              </button>
            </form>
          </div>

          <!-- Mapa -->
          <div class="rounded-3xl overflow-hidden shadow-sm border border-gray-100 h-80 bg-gray-200 relative">
             <!-- Placeholder para Iframe do Google Maps -->
             <div class="absolute inset-0 flex items-center justify-center bg-gray-100">
               <div class="text-center">
                 <MapPin class="w-12 h-12 text-gray-400 mx-auto mb-2" aria-hidden="true" />
                 <p class="text-gray-500 font-medium">Mapa da Penha, RJ</p>
                 <p class="text-xs text-gray-400">[Substituir por iframe do Google Maps]</p>
               </div>
             </div>
             <iframe 
               src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14704.9189498212!2d-43.2849419!3d-22.8465492!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x997b8fbb52cdd7%3A0x6b10d32fba64069f!2sPenha%2C%20Rio%20de%20Janeiro%20-%20RJ!5e0!3m2!1spt-BR!2sbr!4v1715000000000!5m2!1spt-BR!2sbr" 
               width="100%" 
               height="100%" 
               style="border:0;" 
               allowfullscreen="" 
               loading="lazy" 
               referrerpolicy="no-referrer-when-downgrade"
               class="absolute inset-0 opacity-50 mix-blend-multiply"
               title="Mapa da Localização do Instituto na Penha"
             ></iframe>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>
