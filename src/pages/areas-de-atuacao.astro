---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { HeartPulse, BookOpen, Brush, TreePine, Users } from 'lucide-astro';

const title = "Áreas de Atuação";
const description = "Descubra como o MultiplicaRio atua na Saúde, Educação, Cultura, Meio Ambiente e Assistência Social.";

const areas = [
  {
    id: "saude",
    title: "Saúde",
    direction: "normal",
    badgeColor: "bg-primary",
    badgeSide: "right",
    badgeRotate: "rotate-3",
    img: "https://i.ibb.co/QvjF1f6q/Whats-App-Image-2026-06-22-at-07-28-01-2.jpg",
    imgAlt: "Profissional de saúde atendendo paciente na comunidade",
    text: "Acreditamos que a saúde é a base para o desenvolvimento humano. Promovemos assistência médica preventiva, facilitando o acesso da comunidade a profissionais qualificados. Investimos na formação de agentes comunitários de saúde, multiplicando o cuidado.",
  },
  {
    id: "educacao",
    title: "Educação",
    direction: "reverse",
    badgeColor: "bg-secondary",
    badgeSide: "left",
    badgeRotate: "-rotate-3",
    img: "https://i.ibb.co/8gYZqnX7/Whats-App-Image-2026-06-22-at-07-27-58-2.jpg",
    imgAlt: "Crianças estudando em sala de aula",
    text: "Garantir gratuidade e excelência educacional é o nosso maior objetivo. Adotamos métodos pedagógicos inovadores e buscamos integração constante entre escola, família e comunidade, criando um ecossistema onde o aprendizado não termina nos portões da escola.",
  },
  {
    id: "cultura",
    title: "Cultura",
    direction: "normal",
    badgeColor: "bg-accent",
    badgeSide: "right",
    badgeRotate: "rotate-3",
    img: "https://i.ibb.co/JPpm3ZD/Whats-App-Image-2026-06-22-at-07-28-01.jpg",
    imgAlt: "Atividade cultural e artística na comunidade",
    text: "A cultura constrói a identidade de um povo. Atuamos na preservação do patrimônio histórico e artístico local e no fomento de atividades culturais como oficinas de arte, música e festivais que valorizam os talentos da região da Penha.",
  },
  {
    id: "meio-ambiente",
    title: "Meio Ambiente",
    direction: "reverse",
    badgeColor: "bg-primary-dark",
    badgeSide: "left",
    badgeRotate: "-rotate-3",
    img: "https://i.ibb.co/vCh7NhmK/Whats-App-Image-2026-06-22-at-07-27-59-2.jpg",
    imgAlt: "Plantio e cuidado com o meio ambiente na comunidade",
    text: "Defesa, preservação e conservação ambiental são inegociáveis. Desenvolvemos projetos de conscientização ecológica, hortas comunitárias, reciclagem e iniciativas de desenvolvimento sustentável, ensinando as novas gerações a cuidarem do amanhã.",
  },
  {
    id: "assistencia-social",
    title: "Assistência Social",
    direction: "normal",
    badgeColor: "bg-primary",
    badgeSide: "right",
    badgeRotate: "rotate-3",
    img: "https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=800&auto=format&fit=crop",
    imgAlt: "Voluntários auxiliando famílias em situação de vulnerabilidade",
    text: "Através de serviços socioassistenciais, garantimos que os direitos fundamentais sejam respeitados. Nosso foco é proteger famílias em situação de extrema vulnerabilidade, provendo necessidades básicas e amparo contínuo.",
  },
];

const icons = {
  saude: HeartPulse,
  educacao: BookOpen,
  cultura: Brush,
  "meio-ambiente": TreePine,
  "assistencia-social": Users,
};
---

<BaseLayout title={title} description={description}>

  <!-- Page Header com imagem -->
  <section class="relative bg-primary/15 overflow-hidden py-28 md:py-36">
    <div class="absolute inset-0 z-0">
      <img
        src="https://i.ibb.co/RTwSf2PZ/Whats-App-Image-2026-06-22-at-07-27-59.jpg"
        alt="Voluntários do MultiplicaRio"
        width="1400" height="700"
        class="w-full h-full object-cover opacity-20"
        fetchpriority="high" decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-offwhite/95 via-bg-offwhite/80 to-bg-offwhite/20"></div>
      <div class="absolute inset-0 dot-pattern opacity-20 pointer-events-none"></div>
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl relative z-10">
      <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary-dark bg-secondary/40 px-4 py-1.5 rounded-full border border-secondary/60 mb-6">
        O que fazemos
      </span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6" style="letter-spacing: -0.03em;">
        Nossas Áreas de Atuação
      </h1>
      <p class="text-xl text-text-body/75 leading-relaxed max-w-2xl mx-auto">
        Atuamos de forma sistêmica em múltiplos pilares para garantir o desenvolvimento pleno das comunidades e promover mudanças reais e duradouras.
      </p>
    </div>
  </section>

  <!-- Áreas -->
  <section class="py-16 md:py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl space-y-24">

      <!-- Saúde -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-xl border-4 border-bg-offwhite">
            <img src="https://i.ibb.co/QvjF1f6q/Whats-App-Image-2026-06-22-at-07-28-01-2.jpg" alt="Profissional de saúde com paciente" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-primary rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <HeartPulse class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <span class="section-label">Área 01</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Saúde</h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            Acreditamos que a saúde é a base para o desenvolvimento humano. Promovemos assistência médica preventiva, facilitando o acesso da comunidade a profissionais qualificados. Investimos na formação e capacitação de agentes comunitários de saúde, multiplicando o cuidado.
          </p>
        </div>
      </div>

      <!-- Educação -->
      <div class="flex flex-col md:flex-row-reverse gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-xl border-4 border-bg-offwhite">
            <img src="https://i.ibb.co/8gYZqnX7/Whats-App-Image-2026-06-22-at-07-27-58-2.jpg" alt="Crianças estudando em sala de aula" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -left-2 sm:-left-4 w-20 h-20 bg-secondary rounded-2xl flex items-center justify-center shadow-xl -rotate-3">
            <BookOpen class="w-10 h-10 text-primary-dark" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <span class="section-label">Área 02</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Educação</h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            Garantir gratuidade e excelência educacional é o nosso maior objetivo. Adotamos métodos pedagógicos inovadores e buscamos integração constante entre escola, família e comunidade, criando um ecossistema onde o aprendizado não termina nos portões da escola.
          </p>
        </div>
      </div>

      <!-- Cultura -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-xl border-4 border-bg-offwhite">
            <img src="https://i.ibb.co/JPpm3ZD/Whats-App-Image-2026-06-22-at-07-28-01.jpg" alt="Expressão cultural e artística na comunidade" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-accent rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <Brush class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <span class="section-label">Área 03</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Cultura</h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            A cultura constrói a identidade de um povo. Atuamos na preservação do patrimônio histórico e artístico local e no fomento de atividades culturais como oficinas de arte, música e festivais que valorizam os talentos da região da Penha.
          </p>
        </div>
      </div>

      <!-- Meio Ambiente -->
      <div class="flex flex-col md:flex-row-reverse gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-xl border-4 border-bg-offwhite">
            <img src="https://i.ibb.co/vCh7NhmK/Whats-App-Image-2026-06-22-at-07-27-59-2.jpg" alt="Plantio e cuidado com o meio ambiente" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -left-2 sm:-left-4 w-20 h-20 bg-primary-dark rounded-2xl flex items-center justify-center shadow-xl -rotate-3">
            <TreePine class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <span class="section-label">Área 04</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Meio Ambiente</h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            Defesa, preservação e conservação ambiental são inegociáveis. Desenvolvemos projetos de conscientização ecológica, hortas comunitárias, reciclagem e iniciativas de desenvolvimento sustentável, ensinando as novas gerações a cuidarem do amanhã.
          </p>
        </div>
      </div>

      <!-- Assistência Social -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-xl border-4 border-bg-offwhite">
            <img src="https://i.ibb.co/XZHsd9ys/Whats-App-Image-2026-06-22-at-07-27-59-3.jpg" alt="Voluntários auxiliando famílias da comunidade" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-primary rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <Users class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <span class="section-label">Área 05</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Assistência Social</h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            Através de serviços socioassistenciais, garantimos que os direitos fundamentais sejam respeitados. Nosso foco é proteger famílias em situação de extrema vulnerabilidade, provendo necessidades básicas e amparo contínuo.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- Faixa de impacto visual -->
  <section class="py-0 overflow-hidden">
    <div class="grid grid-cols-5 h-48 md:h-64">
      <div class="overflow-hidden">
        <img src="https://i.ibb.co/QvjF1f6q/Whats-App-Image-2026-06-22-at-07-28-01-2.jpg" alt="Saúde" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" decoding="async" />
      </div>
      <div class="overflow-hidden">
        <img src="https://i.ibb.co/8gYZqnX7/Whats-App-Image-2026-06-22-at-07-27-58-2.jpg" alt="Educação" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" decoding="async" />
      </div>
      <div class="overflow-hidden">
        <img src="https://i.ibb.co/JPpm3ZD/Whats-App-Image-2026-06-22-at-07-28-01.jpg" alt="Cultura" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" decoding="async" />
      </div>
      <div class="overflow-hidden">
        <img src="https://i.ibb.co/vCh7NhmK/Whats-App-Image-2026-06-22-at-07-27-59-2.jpg" alt="Meio Ambiente" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" decoding="async" />
      </div>
      <div class="overflow-hidden">
        <img src="https://i.ibb.co/XZHsd9ys/Whats-App-Image-2026-06-22-at-07-27-59-3.jpg" alt="Assistência Social" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <CTASection
    title="Quer fazer a diferença?"
    subtitle="Escolha a área que mais toca o seu coração e contribua para o desenvolvimento da nossa comunidade."
  />
</BaseLayout>
