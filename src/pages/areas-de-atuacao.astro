---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { HeartPulse, BookOpen, Brush, TreePine, Users } from 'lucide-astro';

const title = "Áreas de Atuação";
const description = "Descubra como o Instituto MultiplicaRio atua na Saúde, Educação, Cultura, Meio Ambiente e Assistência Social.";
---

<BaseLayout title={title} description={description}>
  <!-- Page Header -->
  <section class="bg-primary-dark text-bg-offwhite py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">Nossas Áreas de Atuação</h1>
      <p class="text-xl text-bg-lightgreen/80 leading-relaxed">
        Atuamos de forma sistêmica em múltiplos pilares para garantir o desenvolvimento pleno das comunidades e promover mudanças reais e duradouras.
      </p>
    </div>
  </section>

  <section class="py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl space-y-24">
      
      <!-- Saúde -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-lg border-4 border-bg-offwhite">
            <img src="https://images.unsplash.com/photo-1505751172876-fa1923c5c528?q=80&w=800&auto=format&fit=crop" alt="Área da Saúde" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-primary rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <HeartPulse class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <h2 class="font-serif text-3xl font-bold text-primary-dark">Saúde</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            Acreditamos que a saúde é a base para o desenvolvimento humano. Promovemos a saúde através de assistência médica preventiva, facilitando o acesso da comunidade a profissionais qualificados. Também investimos fortemente na formação e capacitação de profissionais de saúde comunitários, multiplicando o cuidado.
          </p>
        </div>
      </div>

      <!-- Educação -->
      <div class="flex flex-col md:flex-row-reverse gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-lg border-4 border-bg-offwhite">
            <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=800&auto=format&fit=crop" alt="Área da Educação" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -left-2 sm:-left-4 w-20 h-20 bg-secondary rounded-2xl flex items-center justify-center shadow-xl -rotate-3">
            <BookOpen class="w-10 h-10 text-primary-dark" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <h2 class="font-serif text-3xl font-bold text-primary-dark">Educação</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            Garantir gratuidade e excelência educacional é o nosso maior objetivo. Adotamos métodos pedagógicos inovadores e buscamos uma integração constante entre escola, família e comunidade, criando um ecossistema onde o aprendizado não termina nos portões da escola.
          </p>
        </div>
      </div>

      <!-- Cultura -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-lg border-4 border-bg-offwhite">
            <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=800&auto=format&fit=crop" alt="Área da Cultura" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-accent rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <Brush class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <h2 class="font-serif text-3xl font-bold text-primary-dark">Cultura</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            A cultura constrói a identidade de um povo. Atuamos na preservação do patrimônio histórico e artístico local e no fomento intenso de atividades culturais, como oficinas de arte, música, e festivais que valorizam os talentos da região da Penha.
          </p>
        </div>
      </div>

      <!-- Meio Ambiente -->
      <div class="flex flex-col md:flex-row-reverse gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-lg border-4 border-bg-offwhite">
            <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&w=800&auto=format&fit=crop" alt="Área do Meio Ambiente" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -left-2 sm:-left-4 w-20 h-20 bg-primary-dark rounded-2xl flex items-center justify-center shadow-xl -rotate-3">
            <TreePine class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <h2 class="font-serif text-3xl font-bold text-primary-dark">Meio Ambiente</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            Defesa, preservação e conservação ambiental são inegociáveis. Desenvolvemos projetos de conscientização ecológica, hortas comunitárias, reciclagem e iniciativas com foco em desenvolvimento sustentável, ensinando as novas gerações a cuidarem do amanhã.
          </p>
        </div>
      </div>

      <!-- Assistência Social -->
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/3 relative flex justify-center">
          <div class="w-full aspect-square rounded-3xl overflow-hidden shadow-lg border-4 border-bg-offwhite">
            <img src="https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?q=80&w=800&auto=format&fit=crop" alt="Área da Assistência Social" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-2 sm:-right-4 w-20 h-20 bg-primary rounded-2xl flex items-center justify-center shadow-xl rotate-3">
            <Users class="w-10 h-10 text-white" aria-hidden="true" />
          </div>
        </div>
        <div class="md:w-2/3 space-y-4 text-center md:text-left">
          <h2 class="font-serif text-3xl font-bold text-primary-dark">Assistência Social</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            Através de serviços socioassistenciais, garantimos que os direitos fundamentais sejam respeitados. Nosso foco é proteger famílias em situação de extrema vulnerabilidade, provendo necessidades básicas e amparo contínuo.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <CTASection 
    title="Quer fazer a diferença?"
    subtitle="Escolha a área que mais toca o seu coração e contribua para o desenvolvimento da nossa comunidade."
  />
</BaseLayout>
