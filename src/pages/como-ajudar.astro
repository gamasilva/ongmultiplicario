---
import BaseLayout from '../layouts/BaseLayout.astro';
import DonationTierCard from '../components/DonationTierCard.astro';
import { Copy, QrCode, CreditCard, Gift, Users, HeartPulse, ShieldCheck, Building2, ArrowRight } from 'lucide-astro';

const title = "Como Ajudar";
const description = "Faça sua doação via PIX, torne-se um voluntário ou doe itens. Toda ajuda multiplica a esperança na vida de quem precisa.";
---

<BaseLayout title={title} description={description}>

  <!-- ───── HERO COM IMAGEM ───── -->
  <section class="relative bg-primary/15 overflow-hidden py-28 md:py-36 text-center">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=1400&auto=format&fit=crop&q=80"
        alt="Mãos unidas em doação e solidariedade"
        width="1400" height="800"
        class="w-full h-full object-cover opacity-20"
        fetchpriority="high" decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-offwhite/90 via-bg-offwhite/75 to-bg-offwhite/20"></div>
      <div class="absolute inset-0 dot-pattern opacity-20 pointer-events-none"></div>
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl relative z-10">
      <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary-dark bg-secondary/40 px-4 py-1.5 rounded-full border border-secondary/60 mb-6">
        ✦ Faça a diferença
      </span>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6" style="letter-spacing: -0.03em;">
        Como Ajudar
      </h1>
      <p class="text-xl text-text-body/75 leading-relaxed max-w-2xl mx-auto">
        Sua doação é segura e transparente. Existem várias formas de multiplicar a esperança — escolha a que melhor se adapta a você.
      </p>
    </div>
  </section>

  <!-- ───── COMO SUA DOAÇÃO SE MULTIPLICA ───── -->
  <section class="py-20 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="section-label mb-4 block w-fit mx-auto">Transparência</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4">Como sua doação se multiplica</h2>
        <p class="text-lg text-text-body/75">Independentemente da forma de pagamento, veja o impacto que valores sugeridos podem causar.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <DonationTierCard amount="30" impact="Garante material escolar completo para uma criança durante um mês." />
        <DonationTierCard amount="80" impact="Custeia uma cesta básica nutritiva para uma família em vulnerabilidade." isPopular={true} />
        <DonationTierCard amount="150" impact="Financia atendimento médico preventivo para três idosos." />
      </div>
    </div>
  </section>

  <!-- ───── FORMAS DE DOAÇÃO ───── -->
  <section class="py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="flex items-center justify-center gap-2 mb-10 bg-primary/15 text-primary-dark max-w-xl mx-auto px-5 py-2.5 rounded-full border border-primary/25 text-center">
        <ShieldCheck class="w-5 h-5 text-primary-dark flex-shrink-0" aria-hidden="true" />
        <span class="text-xs sm:text-sm font-bold leading-snug">Ambiente 100% seguro. Suas informações são criptografadas.</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- Doação PIX -->
        <div class="bg-white p-6 sm:p-8 md:p-10 rounded-3xl shadow-lg border-2 border-primary relative overflow-hidden">
          <!-- QR Code badge -->
          <div class="absolute top-0 right-0 p-4 bg-primary rounded-bl-3xl">
            <QrCode class="w-8 h-8 text-primary-dark" aria-hidden="true" />
          </div>

          <h2 class="font-serif text-3xl font-bold text-gray-900 mb-3">Doação via PIX</h2>
          <p class="text-text-body/70 mb-7 leading-relaxed text-sm">A forma mais rápida e direta de ajudar. O valor cai na hora e é revertido imediatamente para nossos projetos.</p>

          <!-- Chave PIX -->
          <div class="bg-bg-lightgreen/60 border border-primary/20 p-4 sm:p-6 rounded-2xl mb-7 flex flex-col items-center justify-center space-y-3">
            <span class="text-xs text-text-body/50 font-bold uppercase tracking-widest">Chave PIX — CNPJ</span>
            <span class="text-lg sm:text-2xl md:text-3xl font-mono font-bold text-primary-dark select-all break-all text-center" id="pix-key">62.559.044/0001-03</span>
            <button
              id="copy-btn"
              class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-primary-dark hover:text-bg-offwhite px-6 py-3 rounded-full font-bold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary mt-1 shadow-sm"
              aria-label="Copiar chave PIX"
            >
              <Copy class="w-4 h-4" aria-hidden="true" />
              <span>Copiar Chave</span>
            </button>
          </div>

          <p class="text-center text-xs text-gray-400">MultiplicaRio · Banco: [INSERIR BANCO]</p>
        </div>

        <!-- Transferência & Recorrente -->
        <div class="space-y-6">
          <div class="bg-white p-7 rounded-3xl shadow-sm border border-gray-100 flex gap-5 items-start hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-secondary/25 rounded-xl flex items-center justify-center flex-shrink-0 text-secondary-dark mt-0.5">
              <CreditCard class="w-6 h-6" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-serif text-xl font-bold text-gray-900 mb-2">Transferência Bancária</h3>
              <p class="text-text-body/70 text-sm mb-3">Para doações via TED ou DOC:</p>
              <ul class="text-sm font-mono text-gray-600 space-y-1 bg-bg-offwhite p-3 rounded-xl">
                <li><span class="text-gray-400">Banco:</span> [Nome do Banco]</li>
                <li><span class="text-gray-400">Agência:</span> [0000]</li>
                <li><span class="text-gray-400">Conta Corrente:</span> [00000-0]</li>
                <li><span class="text-gray-400">CNPJ:</span> 62.559.044/0001-03</li>
              </ul>
            </div>
          </div>

          <div class="bg-white p-7 rounded-3xl shadow-sm border border-gray-100 flex gap-5 items-start hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-accent/15 rounded-xl flex items-center justify-center flex-shrink-0 text-accent-hover mt-0.5">
              <HeartPulse class="w-6 h-6" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-serif text-xl font-bold text-gray-900 mb-2">Doação Recorrente</h3>
              <p class="text-text-body/70 text-sm mb-3">Torne-se um mantenedor. Sua contribuição mensal garante a estabilidade dos nossos projetos de longo prazo.</p>
              <a href="/contato" class="inline-flex items-center gap-2 text-accent-hover font-bold text-sm hover:gap-3 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm">
                Configurar doação mensal <ArrowRight class="w-4 h-4" aria-hidden="true" />
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ───── OUTRAS FORMAS ───── -->
  <section class="py-24 bg-primary/10 relative overflow-hidden">
    <div class="absolute inset-0 dot-pattern opacity-20 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-72 h-72 rounded-full bg-secondary/20 -mt-20 -mr-20 blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl relative z-10">
      <div class="text-center mb-14">
        <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary-dark bg-secondary/40 px-4 py-1.5 rounded-full border border-secondary/60 mb-5">
          Mais formas de ajudar
        </span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4">Outras Formas de Multiplicar</h2>
        <p class="text-lg text-text-body/65">O seu tempo e os seus bens também são muito valiosos para nós.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Voluntariado -->
        <div class="group rounded-3xl overflow-hidden shadow-sm border border-gray-100 flex flex-col bg-white">
          <div class="h-48 overflow-hidden relative">
            <img
              src="https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=700&auto=format&fit=crop&q=80"
              alt="Voluntariado"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy" decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute top-4 left-4 w-10 h-10 bg-secondary rounded-xl flex items-center justify-center shadow-md">
              <Users class="w-5 h-5 text-secondary-dark" aria-hidden="true" />
            </div>
          </div>
          <div class="p-7 flex flex-col flex-grow border-t border-gray-100">
            <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Voluntariado</h3>
            <p class="text-text-body/70 text-sm leading-relaxed mb-5 flex-grow">
              Junte-se ao nosso time! Precisamos de profissionais de saúde, professores, advogados e pessoas com vontade de ajudar em eventos e rotinas do Instituto.
            </p>
            <a href="/contato" class="inline-flex items-center gap-2 bg-secondary text-secondary-dark font-bold px-5 py-2.5 rounded-full text-sm hover:bg-secondary/90 transition-all duration-200 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary">
              Quero ser voluntário <ArrowRight class="w-4 h-4" aria-hidden="true" />
            </a>
          </div>
        </div>

        <!-- Parcerias Corporativas -->
        <div class="group rounded-3xl overflow-hidden shadow-sm border border-gray-100 flex flex-col bg-white">
          <div class="h-48 overflow-hidden relative">
            <img
              src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=700&auto=format&fit=crop&q=80"
              alt="Parceria corporativa"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy" decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute top-4 left-4 w-10 h-10 bg-primary/80 rounded-xl flex items-center justify-center shadow-md">
              <Building2 class="w-5 h-5 text-white" aria-hidden="true" />
            </div>
          </div>
          <div class="p-7 flex flex-col flex-grow border-t border-gray-100">
            <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Parcerias Corporativas</h3>
            <p class="text-text-body/70 text-sm leading-relaxed mb-5 flex-grow">
              Sua empresa pode multiplicar impacto! Oferecemos opções de patrocínio a projetos, voluntariado corporativo e doações via dedução fiscal.
            </p>
            <a href="/contato" class="inline-flex items-center gap-2 border-2 border-primary-dark/30 text-primary-dark font-bold px-5 py-2.5 rounded-full text-sm hover:bg-primary/10 hover:border-primary-dark/50 transition-all duration-200 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
              Ser empresa parceira <ArrowRight class="w-4 h-4" aria-hidden="true" />
            </a>
          </div>
        </div>

        <!-- Doação de Itens -->
        <div class="group rounded-3xl overflow-hidden shadow-sm border border-gray-100 flex flex-col bg-white">
          <div class="h-48 overflow-hidden relative">
            <img
              src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=700&auto=format&fit=crop&q=80"
              alt="Doação de itens"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy" decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute top-4 left-4 w-10 h-10 bg-accent/80 rounded-xl flex items-center justify-center shadow-md">
              <Gift class="w-5 h-5 text-white" aria-hidden="true" />
            </div>
          </div>
          <div class="p-7 flex flex-col flex-grow border-t border-gray-100">
            <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Doação de Itens</h3>
            <p class="text-text-body/70 text-sm leading-relaxed mb-5 flex-grow">
              Aceitamos roupas em bom estado, alimentos não perecíveis, brinquedos, móveis e material escolar. Entregue diretamente em nossa sede na Penha.
            </p>
            <a href="/contato" class="inline-flex items-center gap-2 border-2 border-primary-dark/30 text-primary-dark font-bold px-5 py-2.5 rounded-full text-sm hover:bg-primary/10 hover:border-primary-dark/50 transition-all duration-200 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
              Ver endereço <ArrowRight class="w-4 h-4" aria-hidden="true" />
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    const copyBtn = document.getElementById('copy-btn');
    const pixKey = document.getElementById('pix-key');

    if (copyBtn && pixKey) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pixKey.textContent || '');
          const span = copyBtn.querySelector('span');
          if (span) {
            const originalText = span.textContent;
            span.textContent = 'Copiado! ✓';
            copyBtn.classList.replace('bg-primary', 'bg-green-500');
            setTimeout(() => {
              span.textContent = originalText;
              copyBtn.classList.replace('bg-green-500', 'bg-primary');
            }, 2000);
          }
        } catch (err) {
          console.error('Falha ao copiar:', err);
        }
      });
    }
  </script>
</BaseLayout>
