---
import BaseLayout from '../layouts/BaseLayout.astro';
import AreaCard from '../components/AreaCard.astro';
import StatCard from '../components/StatCard.astro';
import DonationTierCard from '../components/DonationTierCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
import DonateButton from '../components/DonateButton.astro';
import { HeartPulse, BookOpen, Brush, TreePine, Users, ChevronLeft, ChevronRight, Calendar, ArrowRight } from 'lucide-astro';

const title = "Início";
const fullTitle = "MultiplicaRio | ONG de Educação e Saúde na Penha, Rio de Janeiro";
const description = "MultiplicaRio é uma ONG que atua há mais de 10 anos na Penha (RJ) em saúde, educação, cultura, meio ambiente e assistência social. Conheça e doe.";
const heroImage = "https://i.ibb.co/YBZ6G0gD/Whats-App-Image-2026-06-22-at-07-27-57.jpg";
---

<BaseLayout title={title} fullTitle={fullTitle} description={description} heroImage={heroImage}>

  <!-- ───── HERO ───── -->
  <section class="relative bg-primary-dark overflow-hidden min-h-[92vh] flex items-center">
    <!-- Imagem de fundo -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://i.ibb.co/YBZ6G0gD/Whats-App-Image-2026-06-22-at-07-27-57.jpg"
        alt="Comunidade unida"
        width="1920" height="1080"
        class="w-full h-full object-cover object-top opacity-30"
        fetchpriority="high" decoding="async"
      />
      <!-- Gradiente direcional -->
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark via-primary-dark/85 to-primary-dark/30"></div>
      <!-- Gradiente vertical inferior -->
      <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/60 via-transparent to-transparent"></div>
    </div>

    <!-- Decorações -->
    <div class="absolute top-16 right-10 w-80 h-80 rounded-full bg-primary/8 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-20 right-32 w-56 h-56 rounded-full bg-secondary/8 blur-3xl pointer-events-none"></div>
    <!-- Padrão de pontos -->
    <div class="absolute top-0 right-0 w-1/2 h-full dot-pattern opacity-20 pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20 md:py-28">
      <div class="max-w-3xl space-y-7 md:space-y-9">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-primary/20 text-primary border border-primary/30 font-bold text-xs tracking-[0.14em] uppercase animate-fade-up">
          ✦ MultiplicaRio
        </span>

        <!-- Heading -->
        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-bold text-bg-offwhite animate-fade-up animate-fade-up-delay-1" style="letter-spacing: -0.03em; line-height: 1.08;">
          Multiplicando esperança,<br/>
          <span class="text-secondary">transformando vidas</span>
        </h1>

        <!-- Subtítulo -->
        <p class="text-lg sm:text-xl md:text-2xl text-white/80 leading-relaxed max-w-xl font-light animate-fade-up animate-fade-up-delay-2">
          Ajudando a cuidar de vidas e promover o bem-estar social na Penha e região há mais de 10 anos.
        </p>

        <!-- Botões -->
        <div class="flex flex-col sm:flex-row gap-4 pt-2 animate-fade-up animate-fade-up-delay-3">
          <DonateButton variant="primary" class="w-full sm:w-auto justify-center text-lg px-8 py-4" />
          <a
            href="#quem-somos"
            class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-transparent border-2 border-white/40 text-bg-offwhite hover:bg-white/10 hover:border-white/60 px-8 py-4 rounded-full font-bold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-bg-offwhite focus-visible:ring-offset-primary-dark text-lg"
          >
            Conheça nosso trabalho
          </a>
        </div>
      </div>
    </div>

    <!-- Indicador de scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-40 pointer-events-none animate-bounce">
      <div class="w-5 h-8 rounded-full border-2 border-white/50 flex items-start justify-center pt-1.5">
        <div class="w-1 h-2 rounded-full bg-white/70"></div>
      </div>
    </div>
  </section>

  <!-- ───── STATS ───── -->
  <section class="relative z-20 -mt-10 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl">
    <div class="bg-accent rounded-3xl shadow-2xl overflow-hidden ring-1 ring-accent-hover/20">
      <div class="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-white/20">
        <StatCard value="+500" label="Vidas impactadas" delay={0} />
        <StatCard value="10 anos" label="De atuação" delay={150} />
        <StatCard value="5" label="Áreas de atuação" delay={300} />
      </div>
    </div>
  </section>

  <!-- ───── QUEM SOMOS ───── -->
  <section id="quem-somos" class="py-20 md:py-32 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-14 lg:gap-24">

        <!-- Texto -->
        <div class="lg:w-1/2 space-y-6">
          <span class="section-label">Nossa história</span>
          <h2 class="font-serif text-3xl md:text-4xl xl:text-5xl font-bold text-gray-900">
            Quem Somos
          </h2>
          <p class="text-lg text-text-body/75 leading-relaxed">
            O intuito principal do MultiplicaRio é promover o bem-estar e o desenvolvimento social de indivíduos e comunidades, atuando sem fins lucrativos.
          </p>
          <p class="text-lg text-text-body/75 leading-relaxed">
            Trabalhamos incansavelmente nas áreas de educação, saúde, meio ambiente, cultura e direitos humanos, visando à construção de uma sociedade mais justa e solidária.
          </p>
          <div class="pt-2">
            <a href="/sobre" class="inline-flex items-center gap-2 text-primary-dark font-bold hover:gap-3 transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-md p-1">
              Saiba mais sobre nossa história
              <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true" />
            </a>
          </div>
        </div>

        <!-- Imagem -->
        <div class="lg:w-1/2 relative">
          <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl ring-1 ring-gray-200">
            <img
              src="https://i.ibb.co/JPpm3ZD/Whats-App-Image-2026-06-22-at-07-28-01.jpg"
              alt="Voluntários trabalhando"
              width="800" height="800"
              class="w-full h-full object-cover"
              loading="lazy" decoding="async"
            />
          </div>
          <!-- Quote card flutuante -->
          <div class="absolute -bottom-6 -left-6 bg-secondary p-7 rounded-3xl shadow-xl hidden md:block max-w-[240px] ring-1 ring-secondary-dark/10">
            <div class="text-4xl text-secondary-dark/30 font-serif leading-none mb-2">"</div>
            <p class="font-serif font-bold text-lg text-secondary-dark leading-snug">
              Ajudando a cuidar de vidas.
            </p>
            <p class="text-secondary-dark/60 text-sm mt-2 font-medium">Nossa missão</p>
          </div>
          <!-- Dot decorativo -->
          <div class="absolute -top-4 -right-4 w-24 h-24 dot-pattern rounded-2xl opacity-40 pointer-events-none"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ───── ÁREAS DE ATUAÇÃO ───── -->
  <section class="py-20 md:py-28 bg-bg-lightgreen relative overflow-hidden">
    <!-- Decoração sutil -->
    <div class="absolute top-0 right-0 w-1/3 h-full dot-pattern opacity-20 pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-14 md:mb-18">
        <span class="section-label mb-4 block text-center mx-auto w-fit">O que fazemos</span>
        <h2 class="font-serif text-3xl md:text-4xl xl:text-5xl font-bold text-gray-900 mb-5">Nossas Áreas de Atuação</h2>
        <p class="text-base sm:text-lg text-text-body/75">Atuamos de forma integrada para garantir o desenvolvimento pleno das comunidades que apoiamos.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 xl:gap-8">
        <AreaCard title="Saúde" description="Promoção da saúde, assistência médica preventiva e formação de profissionais comunitários.">
          <HeartPulse slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        <AreaCard title="Educação" description="Gratuidade educacional, métodos inovadores e integração total entre escola e comunidade.">
          <BookOpen slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        <AreaCard title="Cultura" description="Preservação do patrimônio histórico e fomento ativo de atividades artístico-culturais locais.">
          <Brush slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        <AreaCard title="Meio Ambiente" description="Defesa, preservação e conservação ambiental com foco em desenvolvimento sustentável.">
          <TreePine slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        <AreaCard title="Assistência Social" description="Serviços socioassistenciais e garantia incondicional dos direitos humanos fundamentais.">
          <Users slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        <!-- Card CTA -->
        <a href="/areas-de-atuacao" class="group bg-primary-dark rounded-2xl p-7 border border-primary-dark/20 hover:shadow-lg transition-all duration-300 hover:-translate-y-1.5 flex flex-col justify-between min-h-[180px]">
          <p class="font-serif text-xl font-bold text-bg-offwhite leading-snug">Ver todas as nossas áreas de atuação</p>
          <div class="flex items-center gap-2 text-secondary font-bold text-sm mt-4 group-hover:gap-3 transition-all duration-200">
            <span>Explorar</span>
            <ArrowRight class="w-4 h-4" aria-hidden="true" />
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ───── SERVIÇOS OFERECIDOS ───── -->
  <section class="py-20 md:py-28 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="section-label mb-4 block w-fit mx-auto">Atendimento à comunidade</span>
        <h2 class="font-serif text-3xl md:text-4xl xl:text-5xl font-bold text-gray-900 mb-5">O que oferecemos</h2>
        <p class="text-lg text-text-body/75">Oferecemos uma ampla gama de serviços gratuitos para apoiar a saúde, os direitos e o bem-estar das famílias da nossa comunidade.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Saúde & Bem-estar -->
        <div class="bg-bg-offwhite rounded-3xl p-8 border border-gray-100 shadow-sm">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-primary/15 rounded-2xl flex items-center justify-center flex-shrink-0">
              <HeartPulse class="w-6 h-6 text-primary-dark" aria-hidden="true" />
            </div>
            <h3 class="font-serif text-xl font-bold text-gray-900">Saúde & Bem-estar</h3>
          </div>
          <ul class="space-y-3">
            {[
              "Aferição de pressão arterial",
              "Teste glicêmico",
              "Reflexologia",
              "Apoio emocional e escuta qualificada",
              "Saúde mental e bem-estar",
            ].map(item => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 8 8"><path d="M1 4l2 2 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="text-text-body/80 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Assistência Social & Jurídica -->
        <div class="bg-bg-offwhite rounded-3xl p-8 border border-gray-100 shadow-sm">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-accent/15 rounded-2xl flex items-center justify-center flex-shrink-0">
              <Users class="w-6 h-6 text-accent-hover" aria-hidden="true" />
            </div>
            <h3 class="font-serif text-xl font-bold text-gray-900">Assistência Social & Jurídica</h3>
          </div>
          <ul class="space-y-3">
            {[
              "Orientação jurídica (INSS, LOAS, BPC)",
              "Cadastro para famílias em situação de vulnerabilidade",
              "Apoio em questões escolares",
              "Empoderamento feminino",
              "Atendimento terapêutico para mulheres",
            ].map(item => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-accent flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 8 8"><path d="M1 4l2 2 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="text-text-body/80 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-10 text-center">
        <a href="/contato" class="inline-flex items-center gap-2 text-primary-dark font-bold hover:gap-3 transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-md p-1">
          Agendar atendimento ou saber mais
          <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <!-- ───── VÍDEO ───── -->
  <section class="py-20 md:py-28 bg-primary-dark relative overflow-hidden">
    <div class="absolute inset-0 dot-pattern opacity-10 pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-primary/10 blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl relative z-10">

      <!-- Cabeçalho -->
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary bg-secondary/15 px-4 py-1.5 rounded-full border border-secondary/30 mb-6">
          Em ação
        </span>
        <h2 class="font-serif text-3xl md:text-4xl xl:text-5xl font-bold text-bg-offwhite mb-5" style="letter-spacing:-0.02em;">
          Conheça um pouco do nosso trabalho
        </h2>
        <p class="text-lg text-white/65 leading-relaxed">
          Realizamos palestras, oficinas e eventos de capacitação gratuitos para jovens e adultos da comunidade. Veja como a transformação acontece na prática.
        </p>
      </div>

      <!-- Player de Vídeo -->
      <div class="flex justify-center">
        <div class="relative w-full max-w-sm rounded-3xl overflow-hidden shadow-[0_32px_64px_-12px_rgba(0,0,0,0.6)] ring-1 ring-white/10 bg-black" style="aspect-ratio: 9/16;">
          <video
            controls
            preload="none"
            poster="https://i.ibb.co/8gYZqnX7/Whats-App-Image-2026-06-22-at-07-27-58-2.jpg"
            class="w-full h-full object-cover"
            aria-label="Vídeo da Palestra de Capacitação Profissional do MultiplicaRio"
          >
            <source src="/V%C3%ADdeo%20Palestra.mp4" type="video/mp4" />
            Seu navegador não suporta reprodução de vídeo.
          </video>
        </div>
      </div>

      <!-- Legenda -->
      <p class="text-center text-white/40 text-sm mt-5 tracking-wide">
        Palestra de Capacitação Profissional · Jovens Aprendiz (14–23 anos) · Penha, Rio de Janeiro
      </p>

    </div>
  </section>

  <!-- ───── AÇÕES REALIZADAS ───── -->
  <section class="py-20 md:py-28 bg-white relative overflow-hidden border-t border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-10 gap-6">
        <div class="max-w-2xl">
          <span class="section-label mb-4 block w-fit">Nosso trabalho</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-3">Ações Realizadas</h2>
          <p class="text-base sm:text-lg text-text-body/75">Acompanhe os projetos recentes e o impacto direto que nossas ações têm na comunidade.</p>
        </div>
        <div class="hidden sm:flex gap-3 flex-shrink-0">
          <button id="prev-action" class="w-12 h-12 rounded-full border-2 border-primary text-primary-dark flex items-center justify-center hover:bg-primary hover:text-white transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary shadow-sm" aria-label="Ação anterior">
            <ChevronLeft class="w-5 h-5" aria-hidden="true" />
          </button>
          <button id="next-action" class="w-12 h-12 rounded-full bg-primary text-primary-dark flex items-center justify-center hover:bg-primary-dark hover:text-white transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary shadow-sm" aria-label="Próxima ação">
            <ChevronRight class="w-5 h-5" aria-hidden="true" />
          </button>
        </div>
      </div>

      <div id="actions-carousel" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-6 no-scrollbar scroll-smooth">

        {[
          { img: "https://i.ibb.co/QvjF1f6q/Whats-App-Image-2026-06-22-at-07-28-01-2.jpg", tag: "Saúde", title: "Aferição de Pressão e Teste Glicêmico", desc: "Oferecemos aferição de pressão arterial, teste glicêmico e reflexologia para a comunidade, promovendo prevenção e cuidado com a saúde de forma gratuita.", alt: "Atendimento de saúde na comunidade" },
          { img: "https://i.ibb.co/8gYZqnX7/Whats-App-Image-2026-06-22-at-07-27-58-2.jpg", tag: "Educação", title: "Apoio em Questões Escolares", desc: "Auxiliamos famílias com dúvidas e dificuldades escolares, orientando pais e responsáveis sobre direitos educacionais e apoio pedagógico.", alt: "Apoio educacional para a comunidade" },
          { img: "https://i.ibb.co/zVpZxwMh/Whats-App-Image-2026-06-22-at-07-28-02-3.jpg", tag: "Assistência Social", title: "Orientação Jurídica Gratuita", desc: "Disponibilizamos advogados para orientação em processos de INSS, LOAS e BPC, além do cadastro de famílias em situação de vulnerabilidade.", alt: "Orientação jurídica para a comunidade" },
          { img: "https://i.ibb.co/vCh7NhmK/Whats-App-Image-2026-06-22-at-07-27-59-2.jpg", tag: "Mulheres", title: "Atendimento Terapêutico para Mulheres", desc: "Programa de apoio emocional, escuta qualificada, empoderamento feminino e saúde mental para mulheres da comunidade da Penha e região.", alt: "Atendimento terapêutico para mulheres" },
        ].map((card) => (
          <div class="flex-none w-[85vw] sm:w-80 md:w-[22rem] snap-start bg-bg-offwhite rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col">
            <div class="h-52 overflow-hidden relative">
              <img src={card.img} alt={card.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
              <span class="absolute bottom-4 left-4 bg-primary-dark/80 backdrop-blur-sm text-secondary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full">
                {card.tag}
              </span>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="font-serif text-xl font-bold text-gray-900 mb-3 leading-snug group-hover:text-primary-dark transition-colors">{card.title}</h3>
              <p class="text-text-body/70 text-sm leading-relaxed mb-5 flex-grow">{card.desc}</p>
              <a href="/contato" class="inline-flex items-center gap-2 text-primary-dark font-bold text-sm hover:gap-3 transition-all duration-200 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm">
                Saber mais <ArrowRight class="w-4 h-4" aria-hidden="true" />
              </a>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ───── DEPOIMENTOS ───── -->
  <section class="py-24 md:py-32 bg-primary-dark relative overflow-hidden">
    <!-- Decorações -->
    <div class="absolute top-0 right-0 w-80 h-80 rounded-full bg-primary/10 -mt-20 -mr-20 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-secondary/8 -mb-16 -ml-16 blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 dot-pattern opacity-20 pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary bg-secondary/15 px-4 py-1.5 rounded-full border border-secondary/30 mb-5">
          Histórias reais
        </span>
        <h2 class="font-serif text-3xl md:text-4xl xl:text-5xl font-bold text-bg-offwhite mb-4">Histórias de Impacto</h2>
        <p class="text-lg text-white/70">Conheça as pessoas que tiveram suas vidas transformadas pelo MultiplicaRio.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <TestimonialCard
          quote="O apoio do MultiplicaRio foi fundamental quando mais precisei. Hoje meus filhos têm acesso à educação de qualidade e eu consegui um trabalho."
          author="Maria Silva"
          role="Moradora da Penha"
          imagePath="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=150&h=150&fit=crop"
        />
        <TestimonialCard
          quote="Ser voluntário aqui me mostrou o verdadeiro significado de comunidade. A transformação que vemos todos os dias é emocionante."
          author="João Ferreira"
          role="Voluntário — Área de Saúde"
          imagePath="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150&h=150&fit=crop"
        />
      </div>
    </div>
  </section>

  <!-- ───── COMO SUA DOAÇÃO AJUDA ───── -->
  <section class="py-20 md:py-28 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="section-label mb-4 block w-fit mx-auto">Transparência</span>
