<script>
  document.addEventListener('DOMContentLoaded', () => {
    const actionsCarousel = document.getElementById('actions-carousel');
    const prevBtn = document.getElementById('prev-action');
    const nextBtn = document.getElementById('next-action');

    if (actionsCarousel && prevBtn && nextBtn) {
      const scrollAmount = 380;
      prevBtn.addEventListener('click', () => { actionsCarousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' }); });
      nextBtn.addEventListener('click', () => { actionsCarousel.scrollBy({ left: scrollAmount, behavior: 'smooth' }); });
    }
  });
</script>
