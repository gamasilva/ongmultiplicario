---
import BaseLayout from '../layouts/BaseLayout.astro';
import AreaCard from '../components/AreaCard.astro';
import StatCard from '../components/StatCard.astro';
import DonationTierCard from '../components/DonationTierCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
import DonateButton from '../components/DonateButton.astro';
import { HeartPulse, BookOpen, Brush, TreePine, Users, ChevronLeft, ChevronRight, Calendar } from 'lucide-astro';

const title = "Início";
const fullTitle = "Instituto MultiplicaRio | ONG de Educação e Saúde na Penha, Rio de Janeiro";
const description = "Instituto MultiplicaRio é uma ONG que atua há mais de 10 anos na Penha (RJ) em saúde, educação, cultura, meio ambiente e assistência social. Conheça e doe.";
const heroImage = "https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=75&w=1400&fm=avif&fit=crop";
---

<BaseLayout title={title} fullTitle={fullTitle} description={description} heroImage={heroImage}>
  <!-- Hero Section -->
  <section class="relative bg-primary-dark overflow-hidden min-h-[90vh] flex items-center">
    <!-- Placeholder Background Image -->
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=75&w=1400&fm=avif&fit=crop"
        alt="Comunidade unida" 
        width="1920" 
        height="1080" 
        class="w-full h-full object-cover opacity-30" 
        fetchpriority="high" 
        decoding="async" 
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark via-primary-dark/80 to-transparent"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-16 md:py-20">
      <div class="max-w-3xl space-y-6 md:space-y-8">
        <span class="inline-block py-1 px-3 rounded-full bg-secondary/20 text-secondary font-bold text-sm tracking-wider uppercase mb-2 border border-secondary/50">
          ONG MultiplicaRio
        </span>
        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-bg-offwhite leading-tight">
          Multiplicando esperança, <span class="text-secondary block">transformando vidas</span>
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-bg-lightgreen/90 leading-relaxed max-w-2xl font-light">
          Ajudando a cuidar de vidas e promover o bem-estar e o desenvolvimento social na Penha e região.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 pt-4 w-full sm:w-auto">
          <DonateButton variant="primary" class="w-full sm:w-auto justify-center text-lg px-8 py-4" />
          <a href="#quem-somos" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-transparent border-2 border-bg-offwhite text-bg-offwhite hover:bg-bg-offwhite hover:text-primary-dark px-8 py-4 rounded-full font-bold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-bg-offwhite focus-visible:ring-offset-primary-dark text-lg">
            Conheça nosso trabalho
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact/Stats Section -->
  <section class="relative z-20 -mt-10 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl">
    <div class="bg-accent rounded-3xl shadow-2xl overflow-hidden">
      <div class="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-white/20">
        <StatCard value="+500" label="Vidas impactadas" delay={0} />
        <StatCard value="10 anos" label="De atuação" delay={150} />
        <StatCard value="5" label="Áreas de atuação" delay={300} />
      </div>
    </div>
  </section>

  <!-- Quem Somos (Resumo) -->
  <section id="quem-somos" class="py-16 md:py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="lg:w-1/2 space-y-6">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary-dark">Quem Somos</h2>
          <p class="text-lg text-text-body/80 leading-relaxed">
            O intuito principal do Instituto MultiplicaRio é promover o bem-estar e o desenvolvimento social de indivíduos e comunidades, atuando sem fins lucrativos.
          </p>
          <p class="text-lg text-text-body/80 leading-relaxed">
            Trabalhamos incansavelmente nas áreas de educação, saúde, meio ambiente, cultura e direitos humanos, visando à construção de uma sociedade mais justa e solidária para todos.
          </p>
          <div class="pt-4">
            <a href="/sobre" class="inline-flex items-center gap-2 text-primary-dark font-bold hover:text-primary transition-colors group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-md p-1">
              Saiba mais sobre nossa história
              <span class="transform transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>
        <div class="lg:w-1/2 relative">
          <div class="aspect-video lg:aspect-square rounded-3xl overflow-hidden shadow-2xl">
             <img src="https://images.unsplash.com/photo-1593113516832-f19b26b38c20?q=75&w=800&fm=avif&fit=crop" alt="Voluntários trabalhando" width="800" height="800" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-secondary text-primary-dark p-8 rounded-3xl shadow-xl hidden md:block max-w-xs">
            <p class="font-serif font-bold text-xl leading-snug">
              "Ajudando a cuidar de vidas."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Áreas de Atuação -->
  <section class="py-16 md:py-24 bg-bg-lightgreen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary-dark mb-4 md:mb-6">Nossas Áreas de Atuação</h2>
        <p class="text-base sm:text-lg text-text-body/80">Atuamos de forma integrada para garantir o desenvolvimento pleno das comunidades que apoiamos.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <AreaCard 
          title="Saúde" 
          description="Promoção da saúde, assistência médica preventiva e formação de profissionais comunitários."
        >
          <HeartPulse slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        
        <AreaCard 
          title="Educação" 
          description="Gratuidade educacional, métodos inovadores e integração total entre escola e comunidade."
        >
          <BookOpen slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        
        <AreaCard 
          title="Cultura" 
          description="Preservação do patrimônio histórico e fomento ativo de atividades artístico-culturais locais."
        >
          <Brush slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        
        <AreaCard 
          title="Meio Ambiente" 
          description="Defesa, preservação e conservação ambiental com foco em desenvolvimento sustentável."
        >
          <TreePine slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
        
        <AreaCard 
          title="Assistência Social" 
          description="Serviços socioassistenciais e garantia incondicional dos direitos humanos fundamentais."
        >
          <Users slot="icon" class="w-6 h-6" aria-hidden="true" />
        </AreaCard>
      </div>
    </div>
  </section>

  <!-- Ações Realizadas (Carrossel) -->
  <section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-10 gap-6">
        <div class="max-w-2xl">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-primary-dark mb-4">Ações Realizadas</h2>
          <p class="text-base sm:text-lg text-text-body/80">Acompanhe os projetos recentes e o impacto direto que nossa comunidade tem recebido através das suas doações.</p>
        </div>
        <!-- Botões do Carrossel -->
        <div class="flex gap-3 hidden sm:flex">
          <button id="prev-action" class="w-12 h-12 rounded-full border-2 border-primary text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Ação anterior">
            <ChevronLeft class="w-6 h-6" aria-hidden="true" />
          </button>
          <button id="next-action" class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center hover:bg-primary-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="Próxima ação">
            <ChevronRight class="w-6 h-6" aria-hidden="true" />
          </button>
        </div>
      </div>
      
      <!-- Container do Carrossel -->
      <div id="actions-carousel" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 no-scrollbar scroll-smooth">
        
        <!-- Card 1 -->
        <div class="flex-none w-[85vw] sm:w-80 md:w-96 snap-start bg-bg-offwhite rounded-3xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col">
          <div class="h-48 sm:h-56 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=75&w=800&fm=avif&fit=crop" alt="Mutirão de Saúde" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-bold text-primary flex items-center gap-1.5 shadow-sm">
              <Calendar class="w-3.5 h-3.5" aria-hidden="true" />
              15 Ago 2025
            </div>
          </div>
          <div class="p-6 md:p-8 flex flex-col flex-grow">
            <span class="text-xs font-bold tracking-widest text-secondary-dark uppercase mb-3">Saúde</span>
            <h3 class="font-serif text-xl md:text-2xl font-bold text-primary-dark mb-3 leading-snug group-hover:text-primary transition-colors">Mutirão de Saúde na Comunidade</h3>
            <p class="text-text-body/80 text-sm md:text-base leading-relaxed mb-6 flex-grow">
              Realizamos mais de 300 atendimentos médicos preventivos, incluindo exames oftalmológicos e vacinação para crianças e idosos da região da Penha.
            </p>
            <a href="#" class="text-primary-dark font-bold text-sm hover:text-primary inline-flex items-center gap-2 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm transition-colors">
              Detalhes da ação <span class="transform transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="flex-none w-[85vw] sm:w-80 md:w-96 snap-start bg-bg-offwhite rounded-3xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col">
          <div class="h-48 sm:h-56 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?q=75&w=800&fm=avif&fit=crop" alt="Distribuição de Kits" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-bold text-primary flex items-center gap-1.5 shadow-sm">
              <Calendar class="w-3.5 h-3.5" aria-hidden="true" />
              02 Fev 2025
            </div>
          </div>
          <div class="p-6 md:p-8 flex flex-col flex-grow">
            <span class="text-xs font-bold tracking-widest text-secondary-dark uppercase mb-3">Educação</span>
            <h3 class="font-serif text-xl md:text-2xl font-bold text-primary-dark mb-3 leading-snug group-hover:text-primary transition-colors">Entrega de Kits Escolares</h3>
            <p class="text-text-body/80 text-sm md:text-base leading-relaxed mb-6 flex-grow">
              Garantimos um início de ano letivo digno para 150 crianças, com a entrega de mochilas, cadernos e materiais completos arrecadados em nossa campanha.
            </p>
            <a href="#" class="text-primary-dark font-bold text-sm hover:text-primary inline-flex items-center gap-2 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm transition-colors">
              Detalhes da ação <span class="transform transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="flex-none w-[85vw] sm:w-80 md:w-96 snap-start bg-bg-offwhite rounded-3xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col">
          <div class="h-48 sm:h-56 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?q=75&w=800&fm=avif&fit=crop" alt="Horta Comunitária" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-bold text-primary flex items-center gap-1.5 shadow-sm">
              <Calendar class="w-3.5 h-3.5" aria-hidden="true" />
              10 Nov 2024
            </div>
          </div>
          <div class="p-6 md:p-8 flex flex-col flex-grow">
            <span class="text-xs font-bold tracking-widest text-secondary-dark uppercase mb-3">Meio Ambiente</span>
            <h3 class="font-serif text-xl md:text-2xl font-bold text-primary-dark mb-3 leading-snug group-hover:text-primary transition-colors">Revitalização e Horta</h3>
            <p class="text-text-body/80 text-sm md:text-base leading-relaxed mb-6 flex-grow">
              Com o apoio de 40 voluntários, transformamos um espaço abandonado em uma praça com horta comunitária, ensinando plantio sustentável às famílias.
            </p>
            <a href="#" class="text-primary-dark font-bold text-sm hover:text-primary inline-flex items-center gap-2 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm transition-colors">
              Detalhes da ação <span class="transform transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="flex-none w-[85vw] sm:w-80 md:w-96 snap-start bg-bg-offwhite rounded-3xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col">
          <div class="h-48 sm:h-56 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?q=75&w=800&fm=avif&fit=crop" alt="Campanha do Agasalho" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-bold text-primary flex items-center gap-1.5 shadow-sm">
              <Calendar class="w-3.5 h-3.5" aria-hidden="true" />
              15 Jun 2024
            </div>
          </div>
          <div class="p-6 md:p-8 flex flex-col flex-grow">
            <span class="text-xs font-bold tracking-widest text-secondary-dark uppercase mb-3">Assistência Social</span>
            <h3 class="font-serif text-xl md:text-2xl font-bold text-primary-dark mb-3 leading-snug group-hover:text-primary transition-colors">Campanha Inverno Quente</h3>
            <p class="text-text-body/80 text-sm md:text-base leading-relaxed mb-6 flex-grow">
              Arrecadamos e distribuímos mais de 2 mil peças de roupas e cobertores para famílias em situação de vulnerabilidade nos dias mais frios do ano.
            </p>
            <a href="#" class="text-primary-dark font-bold text-sm hover:text-primary inline-flex items-center gap-2 w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm transition-colors">
              Detalhes da ação <span class="transform transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="py-24 bg-primary-dark text-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="font-serif text-4xl font-bold text-bg-offwhite mb-6">Histórias de Impacto</h2>
        <p class="text-lg text-bg-lightgreen/80">Conheça as pessoas que tiveram suas vidas transformadas pelo Instituto.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <TestimonialCard 
          quote="O apoio do Instituto foi fundamental quando mais precisei. Hoje meus filhos têm acesso à educação de qualidade e eu consegui um trabalho."
          author="Maria Silva"
          role="Moradora da Penha"
          imagePath="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=150&h=150&fit=crop"
        />
        <TestimonialCard 
          quote="Ser voluntário aqui me mostrou o verdadeiro significado de comunidade. A transformação que vemos todos os dias é emocionante."
          author="João Ferreira"
          role="Voluntário - Área de Saúde"
          imagePath="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150&h=150&fit=crop"
        />
      </div>
    </div>
  </section>

  <!-- Como sua doação ajuda -->
  <section class="py-24 bg-bg-offwhite">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="font-serif text-4xl font-bold text-primary-dark mb-6">Como sua doação ajuda</h2>
        <p class="text-lg text-text-body/80">Cada contribuição é transformada diretamente em ações que mudam a realidade da nossa região.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <DonationTierCard amount="30" impact="Garante material escolar completo para uma criança durante um mês." />
        <DonationTierCard amount="80" impact="Custeia uma cesta básica nutritiva para uma família em situação de vulnerabilidade." isPopular={true} />
        <DonationTierCard amount="150" impact="Financia atendimento médico e psicológico preventivo para três idosos." />
      </div>
    </div>
  </section>

  <!-- Parceiros e Selos -->
  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <h2 class="font-serif text-3xl font-bold text-primary-dark mb-12">Selos e Certificações</h2>
      
      <div class="flex flex-wrap justify-center gap-8 items-center grayscale hover:grayscale-0 transition-all duration-500">
        <!-- Placeholders para selos -->
        <div class="w-32 h-32 bg-white rounded-full flex items-center justify-center shadow-sm border border-gray-200">
          <span class="text-xs font-bold text-gray-600 text-center px-2">[Selo de Transparência]</span>
        </div>
        <div class="w-40 h-24 bg-white rounded-xl flex items-center justify-center shadow-sm border border-gray-200">
          <span class="text-xs font-bold text-gray-600 text-center px-2">[Conselho Municipal]</span>
        </div>
        <div class="w-32 h-32 bg-white rounded-full flex items-center justify-center shadow-sm border border-gray-200">
          <span class="text-xs font-bold text-gray-600 text-center px-2">[OSCIP]</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Formas de se envolver -->
  <section class="py-24 bg-bg-lightgreen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <h2 class="font-serif text-3xl font-bold text-primary-dark mb-6">Outras Formas de se Envolver</h2>
      <p class="text-lg text-text-body/80 mb-12">O seu tempo e os seus bens também são muito valiosos para nós.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <Users class="w-8 h-8 text-secondary" aria-hidden="true" />
            <h3 class="font-serif text-2xl font-bold text-primary-dark">Voluntariado</h3>
          </div>
          <p class="text-text-body/80 mb-6 leading-relaxed">
            Junte-se ao nosso time! Precisamos de profissionais e pessoas com vontade de ajudar em eventos e rotinas da ONG.
          </p>
          <a href="/como-ajudar" class="inline-block text-primary font-bold hover:text-primary-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm p-1 -ml-1">
            Quero ser voluntário &rarr;
          </a>
        </div>
        
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-4 mb-4">
            <Brush class="w-8 h-8 text-accent" aria-hidden="true" />
            <h3 class="font-serif text-2xl font-bold text-primary-dark">Doação de Itens</h3>
          </div>
          <p class="text-text-body/80 mb-6 leading-relaxed">
            Aceitamos roupas, alimentos não perecíveis, brinquedos, móveis e material escolar. Entregue na nossa sede.
          </p>
          <a href="/como-ajudar" class="inline-block text-primary-dark font-bold hover:text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm p-1 -ml-1">
            Ver detalhes de doação &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection />
</BaseLayout>

<script>
  // Script para o carrossel de ações realizadas
  document.addEventListener('DOMContentLoaded', () => {
    const actionsCarousel = document.getElementById('actions-carousel');
    const prevBtn = document.getElementById('prev-action');
    const nextBtn = document.getElementById('next-action');

    if (actionsCarousel && prevBtn && nextBtn) {
      // Avança a largura de aproximadamente 1 card
      const scrollAmount = 350; 
      
      prevBtn.addEventListener('click', () => {
        actionsCarousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });
      
      nextBtn.addEventListener('click', () => {
        actionsCarousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  });
</script>
