---
import { Facebook, Instagram, Twitter, Mail, MapPin, Phone } from 'lucide-astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-dark text-bg-offwhite py-12 border-t border-primary/20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Mini Sobre -->
      <div class="space-y-4">
        <p class="font-serif text-2xl font-bold text-secondary">Instituto MultiplicaRio</p>
        <p class="text-bg-lightgreen/80 text-sm leading-relaxed">
          Ajudando a cuidar de vidas e multiplicar esperança. Promovemos o bem-estar e o desenvolvimento social de indivíduos e comunidades na Penha e região.
        </p>
      </div>

      <!-- Links Rápidos -->
      <div class="space-y-4">
        <h3 class="font-bold text-base tracking-wide uppercase text-bg-offwhite/70">Links Rápidos</h3>
        <nav class="flex flex-col space-y-2" aria-label="Navegação do Rodapé">
          <a href="/sobre" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Sobre Nós</a>
          <a href="/areas-de-atuacao" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Áreas de Atuação</a>
          <a href="/como-ajudar" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Como Ajudar</a>
          <a href="/transparencia" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Transparência</a>
          <a href="/duvidas-frequentes" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Dúvidas Frequentes</a>
          <a href="/contato" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">Contato</a>
          <a href="/privacidade" class="text-bg-lightgreen/80 hover:text-secondary transition-colors w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm mt-2 pt-2 border-t border-primary/20">Política de Privacidade</a>
        </nav>
      </div>

      <!-- Contato -->
      <div class="space-y-4">
        <h3 class="font-bold text-base tracking-wide uppercase text-bg-offwhite/70">Contato</h3>
        <address class="not-italic flex flex-col space-y-3 text-sm text-bg-lightgreen/80">
          <div class="flex items-start gap-2">
            <MapPin class="w-5 h-5 flex-shrink-0 text-secondary" aria-hidden="true" />
            <span>Rua Montevideo, 824 - Loja F - Penha<br />Rio de Janeiro - RJ, 21020-290</span>
          </div>
          <div class="flex items-center gap-2">
            <Phone class="w-5 h-5 flex-shrink-0 text-secondary" aria-hidden="true" />
            <a href="tel:+552164594790" class="hover:text-secondary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm">(21) 6459-4790</a>
          </div>
          <div class="flex items-center gap-2">
            <Mail class="w-5 h-5 flex-shrink-0 text-secondary" aria-hidden="true" />
            <a href="mailto:imultiplicar@gmail.com" class="hover:text-secondary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-sm break-all">imultiplicar@gmail.com</a>
          </div>
        </address>
      </div>

      <!-- Redes Sociais -->
      <div class="space-y-4">
        <h3 class="font-bold text-base tracking-wide uppercase text-bg-offwhite/70">Siga-nos</h3>
        <div class="flex space-x-4">
          <a href="#" class="bg-primary/20 p-2 rounded-full text-bg-offwhite hover:bg-secondary hover:text-primary-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary" aria-label="Instagram">
            <Instagram class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href="#" class="bg-primary/20 p-2 rounded-full text-bg-offwhite hover:bg-secondary hover:text-primary-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary" aria-label="Facebook">
            <Facebook class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href="#" class="bg-primary/20 p-2 rounded-full text-bg-offwhite hover:bg-secondary hover:text-primary-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary" aria-label="Twitter">
            <Twitter class="w-5 h-5" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>

    <!-- Linha de Credibilidade e Direitos -->
    <div class="pt-8 border-t border-primary/30 flex flex-col md:flex-row justify-between items-center gap-4 text-xs" style="color: #91B7B2">
      <p>
        &copy; {currentYear} Instituto MultiplicaRio. Todos os direitos reservados.
      </p>
      <p class="font-medium flex items-center gap-1">
        Organização sem fins lucrativos · CNPJ: <span class="select-all">62.559.044/0001-03</span>
      </p>
    </div>
  </div>
</footer>
