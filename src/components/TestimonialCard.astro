---
import { Quote } from 'lucide-astro';

interface Props {
  quote: string;
  author: string;
  role: string;
  imagePath?: string;
}

const { quote, author, role, imagePath } = Astro.props;
---

<div class="bg-white border border-gray-100 shadow-sm p-8 rounded-3xl relative overflow-hidden">
  <!-- Decoração de fundo -->
  <div class="absolute -bottom-8 -right-8 w-32 h-32 rounded-full bg-primary/10"></div>
  <Quote class="absolute top-6 right-7 w-9 h-9 text-primary/40" aria-hidden="true" />

  <!-- Autor no topo (padrão moderno) -->
  <div class="flex items-center gap-4 mb-6">
    <div class="w-14 h-14 rounded-full overflow-hidden flex-shrink-0 ring-2 ring-primary/30 shadow-md">
      {imagePath ? (
        <img src={imagePath} alt={`Foto de ${author}`} width="56" height="56" class="w-full h-full object-cover" loading="lazy" decoding="async" />
      ) : (
        <div class="w-full h-full bg-primary flex items-center justify-center text-primary-dark font-bold text-xl">
          {author.charAt(0)}
        </div>
      )}
    </div>
    <div>
      <p class="font-bold text-gray-900 text-base">{author}</p>
      <span class="text-sm text-primary-dark/80 font-medium">{role}</span>
    </div>
  </div>

  <p class="text-text-body/80 text-base leading-relaxed relative">"{quote}"</p>
</div>
