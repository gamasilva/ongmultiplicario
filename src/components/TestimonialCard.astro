---
import { Quote } from 'lucide-astro';
import { Image } from 'astro:assets';

interface Props {
  quote: string;
  author: string;
  role: string;
  imagePath?: string;
}

const { quote, author, role, imagePath } = Astro.props;
---

<div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 relative">
  <Quote class="absolute top-6 left-6 w-10 h-10 text-bg-lightgreen opacity-50" aria-hidden="true" />
  <div class="relative z-10">
    <p class="text-text-body/80 italic mb-6 text-lg leading-relaxed pt-4">"{quote}"</p>
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-gray-200 overflow-hidden flex-shrink-0">
        {imagePath ? (
           <img src={imagePath} alt={`Foto de ${author}`} width="56" height="56" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        ) : (
          <div class="w-full h-full bg-bg-lightgreen flex items-center justify-center text-primary font-bold text-xl">
            {author.charAt(0)}
          </div>
        )}
      </div>
      <div>
        <p class="font-bold text-primary-dark">{author}</p>
        <span class="text-sm text-gray-500">{role}</span>
      </div>
    </div>
  </div>
</div>
