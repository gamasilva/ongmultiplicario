---
import DonateButton from './DonateButton.astro';

interface Props {
  title?: string;
  subtitle?: string;
  primaryButtonText?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
}

const {
  title = "Faça parte dessa transformação",
  subtitle = "Sua contribuição é fundamental para continuarmos multiplicando esperança na Penha e no Rio de Janeiro. Cada doação importa.",
  primaryButtonText = "Quero Doar",
  secondaryButtonText = "Conheça nossas ações",
  secondaryButtonHref = "/areas-de-atuacao"
} = Astro.props;
---

<section class="bg-primary-dark py-20 md:py-28 relative overflow-hidden">
  <!-- Padrão de pontos decorativo -->
  <div class="absolute inset-0 dot-pattern opacity-30 pointer-events-none"></div>

  <!-- Círculos decorativos -->
  <div class="absolute top-0 right-0 -mt-24 -mr-24 w-96 h-96 bg-primary rounded-full opacity-15 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-72 h-72 bg-secondary rounded-full opacity-10 blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/3 -translate-y-1/2 w-48 h-48 bg-accent rounded-full opacity-5 blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl mx-auto text-center space-y-6 md:space-y-8">
      <span class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.14em] uppercase text-secondary bg-secondary/15 px-4 py-1.5 rounded-full border border-secondary/30">
        ✦ Faça a diferença
      </span>
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-bg-offwhite leading-tight">
        {title}
      </h2>
      <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4 w-full">
        <DonateButton variant="primary" class="w-full sm:w-auto justify-center text-lg px-8 py-4" />
        <a
          href={secondaryButtonHref}
          class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-transparent border-2 border-white/30 text-bg-offwhite hover:bg-white/10 hover:border-white/50 px-8 py-4 rounded-full font-bold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-bg-offwhite focus-visible:ring-offset-primary-dark text-lg"
        >
          {secondaryButtonText}
        </a>
      </div>
    </div>
  </div>
</section>
