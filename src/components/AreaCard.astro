---
interface Props {
  iconName?: string;
  title: string;
  description: string;
}

const { iconName, title, description } = Astro.props;
---

<div class="group bg-bg-offwhite rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-primary/20 transition-all duration-300 transform hover:-translate-y-1">
  <div class="w-12 h-12 bg-bg-lightgreen text-primary rounded-xl flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-bg-offwhite transition-colors duration-300">
    <!-- Slot for icon -->
    <slot name="icon" />
  </div>
  <h3 class="font-serif text-xl font-bold text-primary-dark mb-2">{title}</h3>
  <p class="text-text-body/80 text-sm leading-relaxed">
    {description}
  </p>
</div>
