---
interface Props {
  size?: 'sm' | 'md';
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const badge = size === 'sm' ? 'w-8 h-8 rounded-lg' : 'w-9 h-9 sm:w-10 sm:h-10 rounded-xl';
const icon  = size === 'sm' ? 'w-[18px] h-[18px]' : 'w-5 h-5 sm:w-[22px] sm:h-[22px]';
const word  = size === 'sm' ? 'text-lg' : 'text-xl sm:text-2xl';
---

<span class={`flex items-center gap-2.5 ${className}`}>
  <!-- Marca: broto crescendo (multiplicação da vida) -->
  <span
    class={`${badge} flex items-center justify-center shadow-sm flex-shrink-0 ring-1 ring-black/5 transition-transform duration-200`}
    style="background: linear-gradient(135deg, #ABE188 0%, #6E8A5A 55%, #5D675B 100%);"
  >
    <svg viewBox="0 0 32 32" fill="none" class={icon} aria-hidden="true">
      <!-- caule -->
      <path d="M16 26V15" stroke="#FFFFFF" stroke-width="2.2" stroke-linecap="round" />
      <!-- folha superior direita -->
      <path d="M16 16c1-4.6 4.6-7.9 9-8.7 .4 4.6-3 8.6-9 8.7Z" fill="#FFFFFF" />
      <!-- folha inferior esquerda -->
      <path d="M16 18.4c-1.3-3.8-4.6-6.2-8.2-6.6 .4 3.9 3.3 6.4 8.2 6.6Z" fill="#FFFFFF" fill-opacity="0.85" />
    </svg>
  </span>

  <!-- Wordmark -->
  <span class={`font-serif font-bold ${word} tracking-tight leading-none text-gray-900 whitespace-nowrap`}>
    Multiplica<span
      style="background: linear-gradient(115deg, #5D675B 0%, #7BA05E 50%, #9AC77A 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;"
    >Rio</span>
  </span>
</span>
