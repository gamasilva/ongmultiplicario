---
import DonateButton from './DonateButton.astro';
import Logo from './Logo.astro';
import { Menu, X } from 'lucide-astro';

const navItems = [
  { href: '/', label: 'Início' },
  { href: '/sobre', label: 'Sobre Nós' },
  { href: '/areas-de-atuacao', label: 'Áreas de Atuação' },
  { href: '/como-ajudar', label: 'Como Ajudar' },
  { href: '/transparencia', label: 'Transparência' },
  { href: '/duvidas-frequentes', label: 'Dúvidas Frequentes' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full bg-bg-offwhite/96 backdrop-blur-md border-b border-gray-100 shadow-sm">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-[72px]">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-lg p-1" aria-label="MultiplicaRio — Início">
        <Logo class="group-hover:[&>span:first-child]:scale-105" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex space-x-1 xl:space-x-1.5 items-center" aria-label="Navegação Principal">
        {navItems.map((item) => {
          const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class={`font-medium text-sm transition-all px-3 py-2 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary ${
                isActive
                  ? 'text-primary-dark font-bold bg-primary/15'
                  : 'text-text-body hover:text-primary-dark hover:bg-primary/10'
              }`}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
        <div class="ml-2">
          <DonateButton />
        </div>
      </nav>

      <!-- Botão hambúrguer (mobile) -->
      <button
        id="mobile-menu-button"
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-xl text-text-body hover:text-primary-dark hover:bg-primary/15 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menu"
      >
        <Menu class="h-5 w-5" aria-hidden="true" />
      </button>

    </div>
  </div>
</header>

<div
  id="mobile-menu-overlay"
  class="lg:hidden fixed inset-0 z-40 bg-black/50 backdrop-blur-sm hidden"
  aria-hidden="true"
></div>

<div
  id="mobile-menu"
  class="lg:hidden fixed inset-y-0 left-0 z-50 w-full max-w-xs bg-bg-offwhite shadow-2xl flex flex-col -translate-x-full transition-transform duration-300 ease-in-out"
  role="dialog"
  aria-modal="true"
  aria-label="Menu de navegação"
>
  <div class="flex items-center justify-between px-5 h-16 border-b border-gray-100 flex-shrink-0">
    <a href="/" class="mobile-nav-link rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label="MultiplicaRio — Ir para o início">
      <Logo size="sm" />
    </a>
    <button
      id="close-mobile-menu"
      type="button"
      class="flex items-center justify-center w-10 h-10 rounded-xl text-text-body hover:text-primary-dark hover:bg-primary/15 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
      aria-label="Fechar menu"
    >
      <X class="h-5 w-5" aria-hidden="true" />
    </button>
  </div>

  <nav class="flex-grow overflow-y-auto px-3 py-4" aria-label="Menu mobile">
    {navItems.map((item) => {
      const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
      return (
        <a
          href={item.href}
          class={`mobile-nav-link flex items-center px-4 py-3.5 rounded-xl mb-1 text-base font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary ${
            isActive
              ? 'bg-primary/20 text-primary-dark'
              : 'text-gray-900 hover:bg-primary/10 hover:text-primary-dark'
          }`}
          aria-current={isActive ? 'page' : undefined}
        >
          {item.label}
        </a>
      );
    })}
  </nav>

  <div class="flex-shrink-0 p-4 border-t border-gray-100">
    <DonateButton class="w-full justify-center py-4 text-base shadow-lg" />
  </div>
</div>

<script>
  function initMobileMenu() {
    const menuBtn  = document.getElementById('mobile-menu-button');
    const closeBtn = document.getElementById('close-mobile-menu');
    const menu     = document.getElementById('mobile-menu');
    const overlay  = document.getElementById('mobile-menu-overlay');
    const navLinks = document.querySelectorAll('.mobile-nav-link');

    if (!menuBtn || !closeBtn || !menu || !overlay) return;

    function openMenu() {
      menu.classList.remove('-translate-x-full');
      overlay.classList.remove('hidden');
      menuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      setTimeout(() => closeBtn.focus(), 50);
    }

    function closeMenu() {
      menu.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
      menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      menuBtn.focus();
    }

    menuBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);
    navLinks.forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuBtn.getAttribute('aria-expanded') === 'true') closeMenu();
    });
  }

  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
